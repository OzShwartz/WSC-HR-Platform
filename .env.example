# Copy to .env and fill in ONE of these to enable real LLM calls in the AI layer.
# Leave both empty to run the pipeline entirely on deterministic fallback narratives
# (no external API calls, no key required).

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
